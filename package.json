{
  "name": "fed25-api-prisma-jickr",
  "version": "1.0.0",
  "main": "dist/server.ts",
  "scripts": {
    "build": "env-cmd --silent bash scripts/build.sh",
    "build-app": "npm run lint && npm run typecheck && node scripts/build.js",
    "check": "run-s lint typecheck type-coverage",
    "debug": "cross-env DEBUG=prisma-jickr:* tsx --watch src/server.ts",
    "dev": "cross-env DEBUG=prisma-jickr:* tsx --watch src/server.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "type-coverage": "type-coverage -p tsconfig.json --at-least 99 --detail --ignore-files \"generated/prisma/internal/*.ts\" --ignore-files \"prisma/seed.ts\"",
    "start": "tsx src/server.ts"
  },
  "keywords": [],
  "author": "Jonas Olson <zup@jonasolson.se>",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.0.3",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "npm-run-all2": "^8.0.4",
    "prisma": "^7.2.0",
    "tsx": "^4.21.0",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  }
}
