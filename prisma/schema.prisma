generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Album {
  id     Int     @id @default(autoincrement())
  title  String
  photos Photo[]
  user   User    @relation(fields: [userId], references: [id])
  userId Int
}

model Photo {
  id      Int     @id @default(autoincrement())
  title   String
  url     String
  comment String?
  albums  Album[]
  user    User    @relation(fields: [userId], references: [id])
  userId  Int
}

model User {
  id         Int     @id @default(autoincrement())
  email      String
  password   String
  first_name String
  last_name  String
  albums     Album[]
  photos     Photo[]
}
